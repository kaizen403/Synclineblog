---
interface Props {
  username: string;
}

const { username } = Astro.props;
---

<div
  id="gh-contrib-wrapper"
  class="w-full rounded-lg border border-[#30363d] bg-[#0d1117] p-4 overflow-x-auto"
  data-username={username}
>
  <p id="gh-contrib-loading" class="text-sm text-neutral-500 font-ubuntu">
    Loading contributions...
  </p>
  <div id="gh-contrib-container" class="hidden">
    <div class="flex items-baseline justify-between mb-3">
      <p id="gh-contrib-count" class="text-sm text-[#7d8590] font-ubuntu"></p>
    </div>
    <div id="gh-contrib-graph" class="w-full min-w-[680px]"></div>
    <div class="flex items-center justify-end gap-1.5 mt-3">
      <span class="text-xs text-[#7d8590] font-ubuntu">Less</span>
      <span class="inline-block w-[10px] h-[10px] rounded-sm bg-[#161b22]"></span>
      <span class="inline-block w-[10px] h-[10px] rounded-sm bg-[#0e4429]"></span>
      <span class="inline-block w-[10px] h-[10px] rounded-sm bg-[#006d32]"></span>
      <span class="inline-block w-[10px] h-[10px] rounded-sm bg-[#26a641]"></span>
      <span class="inline-block w-[10px] h-[10px] rounded-sm bg-[#39d353]"></span>
      <span class="text-xs text-[#7d8590] font-ubuntu">More</span>
    </div>
  </div>
  <p id="gh-contrib-error" class="hidden text-sm text-red-400 font-ubuntu">
    Failed to load contributions.
  </p>
</div>

<script>
  const COLORS = ["#161b22", "#0e4429", "#006d32", "#26a641", "#39d353"];
  const MONTHS = [
    "Jan", "Feb", "Mar", "Apr", "May", "Jun",
    "Jul", "Aug", "Sep", "Oct", "Nov", "Dec",
  ];
  const DAYS = ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"];

  async function init() {
    const wrapper = document.getElementById("gh-contrib-wrapper");
    const loading = document.getElementById("gh-contrib-loading");
    const container = document.getElementById("gh-contrib-container");
    const graph = document.getElementById("gh-contrib-graph");
    const countEl = document.getElementById("gh-contrib-count");
    const errorEl = document.getElementById("gh-contrib-error");

    if (!wrapper || !loading || !container || !graph || !countEl || !errorEl) return;

    const username = wrapper.dataset.username;

    try {
      const res = await fetch(
        `https://github-contributions-api.jogruber.de/v4/${username}?y=last`
      );
      if (!res.ok) throw new Error("API error");
      const data = await res.json();

      const contributions: { date: string; count: number; level: number }[] =
        data.contributions;
      const totalCount = contributions.reduce(
        (sum: number, c: { count: number }) => sum + c.count,
        0
      );

      countEl.textContent = `${totalCount.toLocaleString()} contributions in the last year`;

      // Build week columns from contribution data
      const sorted = [...contributions].sort(
        (a, b) => new Date(a.date).getTime() - new Date(b.date).getTime()
      );

      // Group into weeks (columns)
      const weeks: { date: string; count: number; level: number }[][] = [];
      let currentWeek: { date: string; count: number; level: number }[] = [];

      for (const day of sorted) {
        const d = new Date(day.date);
        if (currentWeek.length === 0 || d.getDay() === 0) {
          if (currentWeek.length > 0) weeks.push(currentWeek);
          currentWeek = [day];
        } else {
          currentWeek.push(day);
        }
      }
      if (currentWeek.length > 0) weeks.push(currentWeek);

      // SVG dimensions
      const cellSize = 11;
      const cellGap = 2;
      const step = cellSize + cellGap;
      const labelWidth = 30;
      const headerHeight = 16;
      const svgWidth = labelWidth + weeks.length * step;
      const svgHeight = headerHeight + 7 * step;

      // Build SVG
      let svg = `<svg width="100%" viewBox="0 0 ${svgWidth} ${svgHeight}" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="GitHub contribution graph">`;

      // Month labels
      let lastMonth = -1;
      for (let w = 0; w < weeks.length; w++) {
        const firstDay = new Date(weeks[w][0].date);
        const month = firstDay.getMonth();
        if (month !== lastMonth) {
          lastMonth = month;
          const x = labelWidth + w * step;
          svg += `<text x="${x}" y="10" fill="#7d8590" font-size="10" font-family="Ubuntu Mono, monospace">${MONTHS[month]}</text>`;
        }
      }

      // Day labels (Mon, Wed, Fri)
      for (const idx of [1, 3, 5]) {
        const y = headerHeight + idx * step + cellSize - 2;
        svg += `<text x="0" y="${y}" fill="#7d8590" font-size="9" font-family="Ubuntu Mono, monospace">${DAYS[idx]}</text>`;
      }

      // Contribution cells
      for (let w = 0; w < weeks.length; w++) {
        for (const day of weeks[w]) {
          const d = new Date(day.date);
          const dow = d.getDay();
          const x = labelWidth + w * step;
          const y = headerHeight + dow * step;
          const color = COLORS[Math.min(day.level, 4)];
          const dateStr = day.date;
          const countStr =
            day.count === 0
              ? "No contributions"
              : day.count === 1
                ? "1 contribution"
                : `${day.count} contributions`;

          svg += `<rect x="${x}" y="${y}" width="${cellSize}" height="${cellSize}" rx="2" ry="2" fill="${color}" data-date="${dateStr}" data-count="${day.count}"><title>${countStr} on ${dateStr}</title></rect>`;
        }
      }

      svg += `</svg>`;
      graph.innerHTML = svg;
      loading.classList.add("hidden");
      container.classList.remove("hidden");
    } catch {
      loading.classList.add("hidden");
      errorEl.classList.remove("hidden");
    }
  }

  init();
</script>
